<form
    action="/updateExpense/<%= data._id %>?_method=PUT"
    method="POST"
>
    <input
        type="text"
        name="title"
        value="<%= data.title %>"
        class="form-control mb-3"
    >
    <br>
    <input
        type="text"
        name="category"
        value="<%= data.category %>"
        class="form-control mb-3"
    ><br>
    <input
        type="text"
        name="amount"
        value="<%= data.amount %>"
        class="form-control mb-3"
    ><br>
    <input
        type="text"
        name="date"
        value="<%= data.date %>"
        class="form-control mb-3"
    ><br>
    <input
        type="text"
        name="desc"
        value="<%= data.desc %>"
        class="form-control mb-3"
    ><br>
    

    

    <button
        type="submit"
        class="btn btn-success"
    >
        Update Expense
    </button>
</form>